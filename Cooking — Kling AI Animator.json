      "parameters": {
        "jsCode": "const duration = Number($json.duration ?? 5);\nconst klingDuration = duration <= 6 ? \"5\" : \"10\";\nconst videoKey = `cooking/${$json.scriptId}/video/clip_${String($json.clipIndex).padStart(2,'0')}_${($json.act ?? 'clip').replace(/[^a-z0-9_]+/gi,'_').toLowerCase()}.mp4`;\n\nreturn [{ json: { ...$json, klingDuration, videoKey } }];"
