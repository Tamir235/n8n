        "body": "={\n  \"model_name\": \"kling-v1-6\",\n  \"image\": \"{{ $json.image_url }}\",\n  \"prompt\": \"{{ $json.kling_prompt }}\",\n  \"negative_prompt\": \"low quality, blurry, watermark, logo, text, cartoon, anime, CGI, plastic skin, deformed hands, extra fingers, duplicate ingredients, floating objects, morphing, artifacts, camera glitches, oversaturated, unnatural lighting\",\n  \"duration\": \"{{ $json.klingDuration }}\",\n  \"aspect_ratio\": \"9:16\",\n  \"cfg_scale\": 0.5\n}",
