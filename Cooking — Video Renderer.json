    {
      "parameters": {
        "jsCode": "const clipItems = $('When Executed by Another Workflow').all();\nconst config = $('Intro/Outro Config').first().json;\nconst srtUrl = $('Build SRT File').first().json.srtUrl;\nconst scriptId = $('Build SRT File').first().json.scriptId;\nconst recipeName = $('Build SRT File').first().json.recipeName;\n\nconst INTRO_VIDEO = config.intro_video_url ?? '';\nconst INTRO_AUDIO = config.intro_audio_url ?? '';\nconst OUTRO_VIDEO = config.outro_video_url ?? '';\nconst OUTRO_AUDIO = config.outro_audio_url ?? '';\nconst INTRO_LEN = Number(config.intro_length ?? 0);\nconst OUTRO_LEN = Number(config.outro_length ?? 0);\nconst DURATION_BUFFER = Number(config.duration_buffer ?? 0.12);\nconst CAPTION_ENABLED = String(config.captions_enabled ?? 'true').toLowerCase() === 'true';\n\nfunction r2(n){ return Number(Number(n).toFixed(2)); }\nfunction r3(n){ return Number(Number(n).toFixed(3)); }\n\nconst sorted = [...clipItems].sort((a,b) => Number(a.json.clipIndex??0) - Number(b.json.clipIndex??0));\nconst videoClips = [], audioClips = [];\nlet t = 0;\n\nif (INTRO_VIDEO && INTRO_AUDIO && INTRO_LEN > 0) {\n  videoClips.push({ start: r2(t), length: r3(INTRO_LEN), asset: { type: 'video', src: INTRO_VIDEO, volume: 0 } });\n  audioClips.push({ start: r2(t), length: r3(INTRO_LEN), asset: { type: 'audio', src: INTRO_AUDIO } });\n  t = r2(t + INTRO_LEN);\n}\n\nfor (const item of sorted) {\n  const j = item.json;\n  if (!j.video_url) throw new Error(`video_url missing at clipIndex ${j.clipIndex}`);\n  if (!j.audio_url) throw new Error(`audio_url missing at clipIndex ${j.clipIndex}`);\n  const len = r3(Number(j.duration) + DURATION_BUFFER);\n  videoClips.push({ start: r2(t), length: len, asset: { type: 'video', src: j.video_url, volume: 0 } });\n  audioClips.push({ start: r2(t), length: len, asset: { type: 'audio', src: j.audio_url } });\n  t = r2(t + Number(j.duration) + DURATION_BUFFER);\n}\n\nif (OUTRO_VIDEO && OUTRO_AUDIO && OUTRO_LEN > 0) {\n  videoClips.push({ start: r2(t), length: r3(OUTRO_LEN), asset: { type: 'video', src: OUTRO_VIDEO, volume: 0 } });\n  audioClips.push({ start: r2(t), length: r3(OUTRO_LEN), asset: { type: 'audio', src: OUTRO_AUDIO } });\n  t = r2(t + OUTRO_LEN);\n}\n\nconst tracks = [];\nif (CAPTION_ENABLED && srtUrl) {\n  tracks.push({ clips: [{ start: 0, length: 'end', position: 'bottom',\n    offset: { x: 0, y: Number(config.caption_offset_y ?? 0.05) },\n    asset: { type: 'caption', src: srtUrl,\n      font: { family: config.caption_font_family ?? 'Montserrat ExtraBold',\n        size: Number(config.caption_font_size ?? 50),\n        color: config.caption_text_color ?? '#ffffff',\n        lineHeight: 0.9,\n        stroke: config.caption_stroke_color ?? '#000000',\n        strokeWidth: Number(config.caption_stroke_width ?? 2.9) } } }] });\n}\ntracks.push({ clips: videoClips });\ntracks.push({ clips: audioClips });\n\nconst today = new Date().toISOString().slice(0,10);\nconst safeRecipe = (recipeName ?? 'cooking').replace(/[^a-z0-9]+/gi,'_').toLowerCase();\nconst finalVideoKey = `cooking/${scriptId}/final/${safeRecipe}_${today}.mp4`;\n\nreturn [{ json: {\n  scriptId, recipeName, finalVideoKey, totalDuration: r2(t),\n  payload: { timeline: { tracks }, output: { format: 'mp4', size: { width: Number(config.output_width??1080), height: Number(config.output_height??1920) } } }\n}}];"
      },
