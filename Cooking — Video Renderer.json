    {
      "parameters": {
        "jsCode": "const clipItems = $('When Executed by Another Workflow').all();\nconst DURATION_BUFFER = 0.12;\nconst WORDS_PER_SEGMENT = 3;\n\nfunction toSrtTime(seconds) {\n  const h = Math.floor(seconds / 3600);\n  const m = Math.floor((seconds % 3600) / 60);\n  const s = Math.floor(seconds % 60);\n  const ms = Math.round((seconds % 1) * 1000);\n  return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')},${String(ms).padStart(3,'0')}`;\n}\n\nconst sorted = [...clipItems].sort((a,b) => Number(a.json.clipIndex??0) - Number(b.json.clipIndex??0));\nconst scriptId = sorted[0].json.scriptId;\nconst recipeName = sorted[0].json.recipe_name ?? 'cooking';\n\nlet currentStart = 0, entryIndex = 1, fullSrt = '';\n\nfor (const item of sorted) {\n  const j = item.json;\n  const clipDuration = Number(j.duration) + DURATION_BUFFER;\n  const words = String(j.voiceover_text ?? '').trim().split(/\\s+/).filter(Boolean);\n  if (!words.length) { currentStart += clipDuration; continue; }\n  const segments = [];\n  for (let i = 0; i < words.length; i += WORDS_PER_SEGMENT) segments.push(words.slice(i, i+WORDS_PER_SEGMENT).join(' '));\n  const segDur = clipDuration / segments.length;\n  segments.forEach((seg, idx) => {\n    const start = currentStart + idx * segDur;\n    const end = start + segDur - 0.05;\n    fullSrt += `${entryIndex}\\n${toSrtTime(start)} --> ${toSrtTime(end)}\\n${seg}\\n\\n`;\n    entryIndex++;\n  });\n  currentStart += clipDuration;\n}\n\nconst srtContent = fullSrt.trim();\nconst srtKey = `cooking/${scriptId}/srt/full_transcript_${Date.now()}.srt`;\nconst srtUrl = `https://pub-37b9b6ddb72f4f18afbe8af4657ccaf4.r2.dev/${srtKey}`;\n\nconst binaryData = await this.helpers.prepareBinaryData(Buffer.from(srtContent,'utf-8'),'full_transcript.srt','text/plain');\nreturn [{ json: { scriptId, recipeName, srtKey, srtUrl }, binary: { data: binaryData } }];"
      },
