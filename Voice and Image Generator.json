            "parameters": {
                "jsCode": "const crypto = require(\"crypto\");\n\nif (!$json.scriptId) {\n  throw new Error(\"scriptId fehlt\");\n}\n\nconst scriptId = $json.scriptId;\nconst clipIndex = $json.clipIndex ?? 0;\nconst news_type = $json.news_type ?? \"clip\";\nconst image_prompt = $json.image_prompt ?? \"no_prompt\";\n\nconst imageHash = crypto.createHash(\"sha256\")\n  .update(JSON.stringify({ image_prompt }))\n  .digest(\"hex\")\n  .slice(0, 12);\n\nconst safeType = news_type\n  .replace(/[^a-z0-9_]+/gi, \"_\")\n  .toLowerCase();\n\nconst imageKey = `reels/${scriptId}/image/clip_${String(clipIndex).padStart(2,\"0\")}_${safeType}__${imageHash}.png`;\n\nreturn [{\n  json: {\n    ...$json,\n    imageHash,\n    imageKey\n  }\n}];"
            },
