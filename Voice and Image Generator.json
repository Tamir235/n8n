                "jsCode": "const base64 = $input.item.json.audio_base64;\n\n// Dauer auslesen\nconst endTimes = $input.item.json.alignment.character_end_times_seconds;\nconst duration = endTimes[endTimes.length - 1] + 0.4;\n\n// Base64 \u2192 Binary\nconst binaryBuffer = Buffer.from(base64, 'base64');\n\nreturn {\n  json: {\n    duration_seconds: duration\n  },\n  binary: {\n    data: await this.helpers.prepareBinaryData(\n      binaryBuffer,\n      'audio.mp3',\n      'audio/mpeg'\n    )\n  }\n};"
