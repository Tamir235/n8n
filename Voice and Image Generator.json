            "parameters": {
                "jsCode": "// ==========================================\n// Subflow Code Node \u2013 INPUT ADAPTED VERSION\n// Run Once for All Items\n// ==========================================\n\nconst inputs = $input.all().map(i => i.json);\n\n// ------------------------------------------\n// 1) scriptId holen\n// ------------------------------------------\nconst scriptId = inputs.find(i => i.scriptId)?.scriptId;\n\nif (!scriptId) {\n  throw new Error(\n    \"scriptId missing. It must be created in the master workflow (format: reel_YYYY-MM-DDTHH-MM-SS-SSSZ).\"\n  );\n}\n\n// ------------------------------------------\n// 2) Clips sammeln\n// ------------------------------------------\nlet rawClips = [];\n\nfor (const it of inputs) {\n  if (Array.isArray(it.clips)) {\n    rawClips.push(...it.clips);\n  }\n}\n\n// ------------------------------------------\n// 3) Clips normalisieren (Input Mapping)\n// ------------------------------------------\nconst normalizedClips = rawClips.map(c => ({\n  news_type:\n    c?.type === \"market_overview\"\n      ? \"market_snapshot\"\n      : c?.type ?? \"news\",\n\n  clip_text:\n    c?.voiceover ??\n    c?.clip_text ??\n    c?.text ??\n    null,\n\n  image_prompt: c?.image_prompt ?? null,\n}));\n\n// ------------------------------------------\n// 4) Finale Liste bauen\n// ------------------------------------------\nlet finalClips = [];\n\nfor (const c of normalizedClips) {\n  if (c.clip_text) {\n    finalClips.push(c);\n  }\n}\n\n// ------------------------------------------\n// 5) Auf exakt 6 Clips bringen\n// ------------------------------------------\nwhile (finalClips.length < 6) {\n  finalClips.push({\n    news_type: \"outro\",\n    clip_text: \"That\u2019s it for today\u2014follow for the next crypto update.\",\n    image_prompt: finalClips[0]?.image_prompt ?? null,\n  });\n}\n\n// Falls mehr als 6 \u2192 schneiden\nfinalClips = finalClips.slice(0, 6);\n\n// ------------------------------------------\n// 6) ElevenLabs Config\n// ------------------------------------------\nconst VOICE_NAME = \"main_voice\";\n\n// ------------------------------------------\n// 7) Return exakt 6 Items\n// ------------------------------------------\nreturn finalClips.map((c, i) => ({\n  json: {\n    scriptId,\n    clipIndex: i,\n    news_type: c.news_type,\n    clip_text: c.clip_text,\n    image_prompt: c.image_prompt,\n    voiceId: VOICE_ID,\n    voiceName: VOICE_NAME,\n  }\n}));"
            },
