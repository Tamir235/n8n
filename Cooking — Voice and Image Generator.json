                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"text\": \"{{ $json.voiceover_text }}\",\n  \"model_id\": \"eleven_multilingual_v2\",\n  \"voice_settings\": {\n    \"stability\": 0.6,\n    \"similarity_boost\": 0.8\n  }\n}",
                "options": {}
            },
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.3,
            "position": [
                1200,
                0
            ],
            "id": "a0000005-0000-0000-0000-000000000005",
            "name": "ElevenLabs TTS"
        },
        {
            "parameters": {
                "jsCode": "const base64 = $input.item.json.audio_base64;\nconst endTimes = $input.item.json.alignment.character_end_times_seconds;\nconst duration = endTimes[endTimes.length - 1] + 0.4;\n\nconst binaryBuffer = Buffer.from(base64, 'base64');\nreturn {\n  json: { duration_seconds: duration },\n  binary: {\n    data: await this.helpers.prepareBinaryData(binaryBuffer, 'audio.mp3', 'audio/mpeg')\n  }\n};"
            },
