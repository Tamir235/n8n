        },
        {
            "parameters": {
                "method": "POST",
                "url": "=https://api.elevenlabs.io/v1/text-to-speech/{{ $json.voiceId }}/with-timestamps",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "xi-api-key",
                            "value": "sk_80d2398d43bbb43af96129c5f383f41623822823576c5bd9"
