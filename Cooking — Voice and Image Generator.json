        {
            "parameters": {
                "jsCode": "const input = $input.first().json;\nconst scriptId = input.scriptId;\nconst clips = input.clips ?? [];\n\nif (!scriptId) throw new Error('scriptId missing');\nif (!clips.length) throw new Error('No clips in input');\n\nreturn clips.map(c => ({\n  json: {\n    scriptId,\n    clipIndex: c.clipIndex ?? 0,\n    act: c.act ?? 'clip',\n    voiceover_text: c.voiceover_text ?? '',\n    kling_prompt: c.kling_prompt ?? '',\n    duration_seconds: c.duration_seconds ?? 5,\n    camera: c.camera ?? '',\n    lens: c.lens ?? '',\n    continuity_note: c.continuity_note ?? '',\n    transition_out: c.transition_out ?? '',\n    voiceId: 'TUKJhQmz3RPYBNAgC5A1'\n  }\n}));"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                300,
                300
            ],
            "id": "a0000002-0000-0000-0000-000000000002",
            "name": "Prepare Clips"
        },
        {
            "parameters": {
                "options": {}
            },
            "type": "n8n-nodes-base.splitInBatches",
            "typeVersion": 3,
            "position": [
                600,
                0
            ],
            "id": "a0000003-0000-0000-0000-000000000003",
            "name": "Loop Audio"
        },
        {
            "parameters": {
                "jsCode": "const crypto = require('crypto');\nconst scriptId = $json.scriptId;\nconst clipIndex = $json.clipIndex ?? 0;\nconst act = ($json.act ?? 'clip').replace(/[^a-z0-9_]+/gi, '_').toLowerCase();\nconst voiceover_text = $json.voiceover_text ?? '';\nconst voiceId = $json.voiceId ?? '';\n\nconst audioHash = crypto.createHash('sha256')\n  .update(JSON.stringify({ voiceover_text, voiceId }))\n  .digest('hex').slice(0, 12);\n\nconst audioKey = `cooking/${scriptId}/audio/clip_${String(clipIndex).padStart(2,'0')}_${act}__${audioHash}.mp3`;\n\nreturn [{ json: { ...$json, audioHash, audioKey } }];"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                900,
                0
            ],
            "id": "a0000004-0000-0000-0000-000000000004",
